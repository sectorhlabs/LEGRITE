# ─── SENSITIVE: Real personal and business data ───
# These CSVs contain real DNI, CIF, names, addresses, phones, emails.
# They are runtime data, NOT source code.
resources/Empresas.csv
resources/Instaladores.csv
resources/Empresas.xlsx
resources/Instaladores.xlsx

# ─── DUPLICATE / OUTDATED BACKUP ───
# Everything in Auxiliar/ is an older copy of resources/ + source
# with additional copies of the same sensitive data.
Auxiliar/

# ─── INTERNAL REFERENCE DOCUMENTS ───
resources/EP*.pdf

# ─── SENSITIVE: Cadastre certificates with property owner data ───
catastro-cli/catastro_output/*.html
catastro-cli/catastro_output/*.pdf

# ─── SENSITIVE: Output PDFs generated by the app ───
# Generated certificates contain personal data of clients
output/
*.cert.pdf

